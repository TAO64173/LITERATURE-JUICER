# ============================================
# Literature Juicer 环境变量配置
# ============================================
# 步骤 1: 复制此文件为 .env（后端本地开发）
# 步骤 2: 按照下方说明填入实际值
# 步骤 3: Render 部署时，在 Dashboard 中设置相同变量

# ----- DeepSeek API（必填） -----
DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ----- Supabase（用户系统必填） -----
# 1. 前往 https://supabase.com 创建项目
# 2. 在 SQL Editor 中执行 supabase/schema.sql
# 3. 在 Settings > API 中获取以下值
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ----- Clerk（用户系统必填） -----
# 1. 前往 https://clerk.com 创建应用
# 2. 启用 Email + Password 认证方式
# 3. 在 API Keys 中获取以下值
# 方式一：JWKS URL（推荐，从 Clerk Dashboard > API Keys > JWKS URL 获取）
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# 方式二：PEM 公钥（二选一）
# CLERK_PEM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Clerk Secret Key（用于从 Clerk API 获取用户邮箱，当 JWT 不含 email 时需要）
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ----- 码支付 Mapay EPay -----
PAY_PID=your_merchant_id
PAY_KEY=your_merchant_key
PAY_API=https://mzf.mapay.cc/xpay/epay/mapi.php
PAY_NOTIFY_URL=https://your-api.onrender.com/payment/notify
PAY_RETURN_URL=https://your-api.onrender.com/payment/return

# ----- CORS（逗号分隔多个域名） -----
# Render 部署后设置为你的前端域名
# CORS_ORIGINS=http://localhost:3000,https://your-app.onrender.com

# ============================================
# 前端环境变量（设置在 frontend/.env.local 或 Render Dashboard）
# ============================================
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
